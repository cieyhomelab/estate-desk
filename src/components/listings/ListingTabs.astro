---
import { PencilLine, Tag, FileText, Users, CircleCheck } from "lucide-react";

interface Props {
  listingId: string;
  activeTab: "edit" | "pricing" | "documents" | "contacts" | "close";
}

const { listingId, activeTab } = Astro.props;

const tabs = [
  { key: "edit" as const, label: "Edytuj", href: `/dashboard/listings/${listingId}/edit` },
  { key: "pricing" as const, label: "Cena i prowizja", href: `/dashboard/listings/${listingId}/pricing` },
  { key: "documents" as const, label: "Dokumenty", href: `/dashboard/listings/${listingId}/documents` },
  { key: "contacts" as const, label: "Kontakty", href: `/dashboard/listings/${listingId}/contacts` },
  { key: "close" as const, label: "Zakończ transakcję", href: `/dashboard/listings/${listingId}/close` },
];
---

<div class="mb-6">
  <a
    href="/dashboard"
    class="mb-3 inline-flex items-center gap-1 text-sm text-white/40 transition-colors hover:text-white/70"
  >
    <span aria-hidden="true">←</span> Powrót do panelu
  </a>
  <div class="flex gap-[5px] rounded-xl border border-white/[0.08] bg-white/[0.04] p-1">
    {
      tabs.map((tab) => {
        const isActive = tab.key === activeTab;
        const isClose = tab.key === "close";
        const icon =
          tab.key === "edit" ? (
            <PencilLine className="h-3 w-3" />
          ) : tab.key === "pricing" ? (
            <Tag className="h-3 w-3" />
          ) : tab.key === "documents" ? (
            <FileText className="h-3 w-3" />
          ) : tab.key === "contacts" ? (
            <Users className="h-3 w-3" />
          ) : (
            <CircleCheck className="h-3 w-3" />
          );

        if (isActive) {
          return (
            <span
              title={tab.label}
              class:list={[
                "flex size-[22px] items-center justify-center rounded-[6px]",
                isClose ? "bg-red-500/20 text-red-300" : "bg-white/[0.14] text-white",
              ]}
            >
              {icon}
            </span>
          );
        }

        return (
          <a
            href={tab.href}
            title={tab.label}
            class:list={[
              "flex size-[22px] items-center justify-center rounded-[6px] transition-colors",
              isClose
                ? "text-red-400/50 hover:bg-red-500/10 hover:text-red-300"
                : "text-white/35 hover:bg-white/[0.08] hover:text-white/60",
            ]}
          >
            {icon}
          </a>
        );
      })
    }
  </div>
</div>
