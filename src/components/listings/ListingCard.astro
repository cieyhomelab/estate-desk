---
import type { Listing } from "@/types/listings";
import { formatPLN } from "@/lib/utils";

interface Props {
  listing: Listing;
}

const { listing } = Astro.props;

const typeLabel = listing.type === "sale" ? "Sprzedaż" : "Najem okazjonalny";
const statusLabel = listing.status === "active" ? "Aktywne" : "Ukończone";
---

<div class="rounded-xl border border-white/10 bg-white/10 p-5 backdrop-blur-xl">
  <div class="mb-3 flex flex-wrap items-start justify-between gap-2">
    <h2 class="text-base font-semibold text-white">{listing.address}</h2>
    <div class="flex gap-2">
      <span class="rounded-full bg-blue-500/20 px-2.5 py-0.5 text-xs font-medium text-blue-200">
        {typeLabel}
      </span>
      <span
        class:list={[
          "rounded-full px-2.5 py-0.5 text-xs font-medium",
          listing.status === "active" ? "bg-green-500/20 text-green-200" : "bg-gray-500/20 text-gray-300",
        ]}
      >
        {statusLabel}
      </span>
    </div>
  </div>

  {listing.owner_name && <p class="mb-1 text-sm text-blue-100/70">{listing.owner_name}</p>}

  <p class="mb-4 text-sm font-medium text-white/80">
    {listing.asking_price ? formatPLN(listing.asking_price) : "Brak ceny"}
  </p>

  <div class="flex flex-wrap gap-2">
    <a
      href={`/dashboard/listings/${listing.id}/edit`}
      class="rounded-lg border border-white/20 bg-white/10 px-3 py-1.5 text-sm text-white transition-colors hover:bg-white/20"
    >
      Edytuj
    </a>
    <a
      href={`/dashboard/listings/${listing.id}/pricing`}
      class="rounded-lg border border-white/20 bg-white/10 px-3 py-1.5 text-sm text-white transition-colors hover:bg-white/20"
    >
      Cena i prowizja
    </a>
    <form method="POST" action={`/api/listings/${listing.id}/delete`}>
      <button
        type="submit"
        onclick="return confirm('Czy na pewno chcesz usunąć to ogłoszenie? Tej operacji nie można cofnąć.')"
        class="rounded-lg border border-red-400/30 bg-red-500/10 px-3 py-1.5 text-sm text-red-300 transition-colors hover:bg-red-500/20"
      >
        Usuń
      </button>
    </form>
  </div>
</div>
