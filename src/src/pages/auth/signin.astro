---
import AuthLayout from "@/layouts/AuthLayout.astro";
import SignInForm from "@/components/auth/SignInForm";

const error = Astro.url.searchParams.get("error");
---

<AuthLayout title="Logowanie">
  <h1 class="mb-1.5 text-[21px] font-bold tracking-[-0.024em] text-white">Zaloguj się</h1>
  <p class="mb-8 text-[13px] font-light text-slate-400/55">Wprowadź dane, aby kontynuować</p>

  <SignInForm serverError={error} client:load />

  <p class="mt-5 text-center text-[12.5px] text-slate-400/40">
    Nie masz konta?{" "}
    <a href="/auth/signup" class="text-blue-400/80 transition-colors hover:text-blue-400">
      Zarejestruj się
    </a>
  </p>
</AuthLayout>
