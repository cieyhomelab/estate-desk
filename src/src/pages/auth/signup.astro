---
import AuthLayout from "@/layouts/AuthLayout.astro";
import SignUpForm from "@/components/auth/SignUpForm";

const error = Astro.url.searchParams.get("error");
---

<AuthLayout title="Rejestracja">
  <h1 class="mb-1.5 text-[21px] font-bold tracking-[-0.024em] text-white">Utwórz konto</h1>
  <p class="mb-8 text-[13px] font-light text-slate-400/55">Dołącz do EstateDesk i zacznij działać</p>

  <SignUpForm serverError={error} client:load />

  <p class="mt-5 text-center text-[12.5px] text-slate-400/40">
    Masz już konto?{" "}
    <a href="/auth/signin" class="text-blue-400/80 transition-colors hover:text-blue-400">
      Zaloguj się
    </a>
  </p>
</AuthLayout>
