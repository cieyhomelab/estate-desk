---
import AuthLayout from "@/layouts/AuthLayout.astro";

const isAutoConfirmed = import.meta.env.DEV;

const content = isAutoConfirmed
  ? {
      heading: "Rejestracja zakończona",
      description: "Twoje konto zostało utworzone. Możesz teraz się zalogować.",
      linkText: "Przejdź do logowania",
    }
  : {
      heading: "Sprawdź skrzynkę",
      description:
        "Wysłaliśmy link potwierdzający na Twój adres e-mail. Kliknij go, aby aktywować konto.",
      linkText: "Wróć do logowania",
    };
---

<AuthLayout title={content.heading}>
  <h1 class="mb-2 text-[21px] font-bold tracking-[-0.024em] text-white">{content.heading}</h1>
  <p class="mb-8 text-[13px] font-light leading-relaxed text-slate-400/60">
    {content.description}
  </p>
  <a
    href="/auth/signin"
    class="text-[13px] text-blue-400/75 transition-colors hover:text-blue-400"
  >
    ← {content.linkText}
  </a>
</AuthLayout>
