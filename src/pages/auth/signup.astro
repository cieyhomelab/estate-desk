---
import Layout from "@/layouts/Layout.astro";
import AuthHero from "@/components/auth/AuthHero.astro";
import SignUpForm from "@/components/auth/SignUpForm";

const error = Astro.url.searchParams.get("error");
---

<Layout title="Utwórz konto">
  <div class="bg-cosmic min-h-screen lg:grid lg:grid-cols-[1.35fr_0.85fr]">
    <AuthHero />

    <section class="auth-panel flex min-h-screen items-center justify-center px-8 py-10">
      <div class="login-card">
        <h2 class="auth-login-title">Utwórz konto</h2>
        <p class="auth-login-subtitle">Wprowadź dane, aby się zarejestrować</p>
        <div class="mt-10">
          <SignUpForm serverError={error} client:load />
        </div>
        <p class="mt-7 text-center text-sm text-slate-400">
          Masz już konto? <a class="auth-link" href="/">Zaloguj się</a>
        </p>
      </div>
    </section>
  </div>
</Layout>
