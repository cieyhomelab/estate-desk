---
import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/Banner.astro";
import DashboardHeader from "@/components/DashboardHeader.astro";
import DashboardListings from "@/components/dashboard/DashboardListings";
import { createClient } from "@/lib/supabase";
import { formatPLN } from "@/lib/utils";
import type { Listing } from "@/types/listings";

const supabase = createClient(Astro.request.headers, Astro.cookies);

let listings: Listing[] = [];
let fetchError: string | null = null;
let snapshotMap = new Map<string, number | null>();

if (!supabase) {
  fetchError = "Błąd konfiguracji bazy danych";
} else {
  const { data, error } = await supabase
    .from("listings")
    .select("*")
    .order("status", { ascending: true })
    .order("created_at", { ascending: false })
    .limit(100)
    .overrideTypes<Listing[], { merge: false }>();

  if (error) {
    fetchError = error.message;
  } else {
    listings = data;

    const doneIds = listings.filter((l) => l.status === "done").map((l) => l.id);
    if (doneIds.length > 0) {
      const { data: snapshots } = await supabase
        .from("transaction_snapshots")
        .select("listing_id, agent_net")
        .in("listing_id", doneIds)
        .is("voided_at", null)
        .limit(doneIds.length)
        .overrideTypes<{ listing_id: string; agent_net: number | null }[], { merge: false }>();
      if (snapshots) {
        snapshotMap = new Map(snapshots.map((s) => [s.listing_id, s.agent_net]));
      }
    }
  }
}

const snapshotRecord: Record<string, number | null> = Object.fromEntries(snapshotMap);

const urlError = Astro.url.searchParams.get("error");
const urlSuccess = Astro.url.searchParams.get("success");

const activeListings = listings.filter((l) => l.status === "active");
const doneListings = listings.filter((l) => l.status === "done");
const totalActiveValue = activeListings.reduce((sum, l) => sum + (l.asking_price ?? 0), 0);

function formatStatMoney(value: number): string {
  if (value === 0) return "—";
  if (value >= 1_000_000) {
    return `${(value / 1_000_000).toFixed(2).replace(".", ",")} mln zł`;
  }
  return formatPLN(value);
}
---

<Layout title="Dashboard — EstateDesk">
  <div class="bg-cosmic min-h-screen">
    <DashboardHeader />

    <div class="mx-auto max-w-4xl px-6 py-8">
      <div class="mb-7">
        <h1 class="text-3xl font-bold tracking-tight text-white">Ogłoszenia</h1>
        <p class="mt-1.5 text-sm text-white/45">
          Zarządzaj ofertami, dokumentami, kontaktami i prowizją w jednym, przejrzystym panelu nieruchomości.
        </p>
      </div>

      <div class="mb-8 grid grid-cols-2 gap-3 sm:grid-cols-4">
        <div class="rounded-xl border border-white/[0.08] bg-white/[0.05] px-4 py-3.5">
          <p class="mb-0.5 text-[0.6875rem] font-medium tracking-wider text-white/40 uppercase">Aktywne oferty</p>
          <p class="text-2xl font-bold text-white">{activeListings.length}</p>
        </div>
        <div class="rounded-xl border border-white/[0.08] bg-white/[0.05] px-4 py-3.5">
          <p class="mb-0.5 text-[0.6875rem] font-medium tracking-wider text-white/40 uppercase">Łączna wartość</p>
          <p class="text-xl font-bold text-white">{formatStatMoney(totalActiveValue)}</p>
        </div>
        <div class="rounded-xl border border-white/[0.08] bg-white/[0.05] px-4 py-3.5">
          <p class="mb-0.5 text-[0.6875rem] font-medium tracking-wider text-white/40 uppercase">W transakcji</p>
          <p class="text-2xl font-bold text-white">{doneListings.length}</p>
        </div>
        <div class="rounded-xl border border-white/[0.08] bg-white/[0.05] px-4 py-3.5">
          <p class="mb-0.5 text-[0.6875rem] font-medium tracking-wider text-white/40 uppercase">Wszystkich</p>
          <p class="text-2xl font-bold text-white">{listings.length}</p>
        </div>
      </div>

      {urlSuccess === "wznowiono" && <Banner variant="info">Ogłoszenie zostało wznowione.</Banner>}
      {urlError && <Banner variant="error">{urlError}</Banner>}
      {fetchError && <Banner variant="error">{fetchError}</Banner>}

      <DashboardListings listings={listings} snapshotMap={snapshotRecord} hasError={!!fetchError} client:load />

      <form method="POST" action="/api/auth/signout" class="mt-10 border-t border-white/[0.06] pt-6">
        <button
          type="submit"
          class="rounded-lg border border-white/[0.12] bg-white/[0.05] px-4 py-2 text-sm text-white/50 transition-colors hover:bg-white/[0.09] hover:text-white/70"
        >
          Wyloguj
        </button>
      </form>
    </div>
  </div>
</Layout>

<style>
  :global(body) {
    background: #0d1b2a;
  }
</style>
