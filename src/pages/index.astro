---
import Layout from "@/layouts/Layout.astro";
import AuthHero from "@/components/auth/AuthHero.astro";
import SignInForm from "@/components/auth/SignInForm";

const error = Astro.url.searchParams.get("error") ?? undefined;
---

<Layout title="EstateDesk">
  <div class="bg-cosmic min-h-screen lg:grid lg:grid-cols-[1.35fr_0.85fr]">
    <AuthHero />

    <section class="auth-panel flex min-h-screen items-center justify-center px-8 py-10">
      <div class="login-card">
        <h2 class="auth-login-title">Zaloguj się</h2>
        <p class="auth-login-subtitle">Wprowadź dane, aby kontynuować</p>
        <div class="mt-10">
          <SignInForm serverError={error} client:only="react" />
        </div>
        <p class="mt-7 text-center text-sm text-slate-400">
          Nie masz konta? <a class="auth-link" href="/auth/signup">Zarejestruj się</a>
        </p>
      </div>
    </section>
  </div>
</Layout>
