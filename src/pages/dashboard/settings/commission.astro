---
import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/Banner.astro";
import DashboardHeader from "@/components/DashboardHeader.astro";
import { createClient } from "@/lib/supabase";
import type { CommissionSettings } from "@/types/pricing";

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) {
  return Astro.redirect("/dashboard?error=" + encodeURIComponent("Błąd konfiguracji bazy danych"));
}

const {
  data: { user },
} = await supabase.auth.getUser();
if (!user) {
  return Astro.redirect("/auth/signin");
}

const { data: settings, error: fetchError } = await supabase
  .from("commission_settings")
  .select("*")
  .eq("user_id", user.id)
  .maybeSingle<CommissionSettings>();

if (fetchError) {
  return Astro.redirect(
    "/dashboard?error=" + encodeURIComponent("Nie udało się pobrać ustawień prowizji. Spróbuj ponownie."),
  );
}

const error = Astro.url.searchParams.get("error");
---

<Layout title="Ustawienia prowizji — EstateDesk">
  <div class="bg-cosmic min-h-screen">
    <DashboardHeader activePage="settings" />

    <div class="mx-auto max-w-lg px-6 py-8">
      <a
        href="/dashboard"
        class="mb-5 inline-flex items-center gap-1 text-sm text-white/40 transition-colors hover:text-white/70"
      >
        <span aria-hidden="true">←</span> Powrót
      </a>

      <div class="rounded-xl border border-white/[0.08] bg-white/[0.06] p-8 backdrop-blur-sm">
        <h1 class="mb-6 text-2xl font-bold text-white">Ustawienia prowizji</h1>

        {
          error && (
            <Banner variant="error">
              {error === "stawki-nieprawidlowe"
                ? "Stawki muszą być liczbami z zakresu 0–100."
                : error === "blad-zapisu"
                  ? "Nie udało się zapisać ustawień. Spróbuj ponownie."
                  : "Wystąpił nieoczekiwany błąd. Spróbuj ponownie."}
            </Banner>
          )
        }

        <form method="POST" action="/api/settings/commission" class="space-y-5">
          <div>
            <label for="tax_rate" class="mb-1 block text-sm font-medium text-white/60">Stawka podatku (%)</label>
            <input
              id="tax_rate"
              type="number"
              name="tax_rate"
              step="0.01"
              min="0"
              max="100"
              value={settings?.tax_rate ?? 0}
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white placeholder-white/25 focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
            />
          </div>

          <div>
            <label for="agency_percent" class="mb-1 block text-sm font-medium text-white/60">Udział agencji (%)</label>
            <input
              id="agency_percent"
              type="number"
              name="agency_percent"
              step="0.01"
              min="0"
              max="100"
              value={settings?.agency_percent ?? 0}
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white placeholder-white/25 focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
            />
          </div>

          <button
            type="submit"
            class="w-full rounded-lg bg-blue-600 py-2.5 font-semibold text-white transition-colors hover:bg-blue-500"
          >
            Zapisz stawki
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>

<style>
  :global(body) {
    background: #0d1b2a;
  }
</style>
