---
import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/Banner.astro";
import { createClient } from "@/lib/supabase";
import type { CommissionSettings } from "@/types/pricing";

const supabase = createClient(Astro.request.headers, Astro.cookies);
if (!supabase) {
  return Astro.redirect("/dashboard?error=" + encodeURIComponent("Błąd konfiguracji bazy danych"));
}

const {
  data: { user },
} = await supabase.auth.getUser();
if (!user) {
  return Astro.redirect("/auth/signin");
}

const { data: settings, error: fetchError } = await supabase
  .from("commission_settings")
  .select("*")
  .eq("user_id", user.id)
  .maybeSingle<CommissionSettings>();

if (fetchError) {
  return Astro.redirect("/dashboard?error=" + encodeURIComponent(fetchError.message));
}

const error = Astro.url.searchParams.get("error");
---

<Layout title="Ustawienia prowizji — EstateDesk">
  <div class="bg-cosmic min-h-screen p-6">
    <div class="mx-auto max-w-lg">
      <a href="/dashboard" class="mb-6 inline-block text-sm text-blue-200/70 transition-colors hover:text-blue-200">
        ← Powrót
      </a>

      <div class="rounded-xl border border-white/10 bg-white/10 p-8 backdrop-blur-xl">
        <h1 class="mb-6 text-2xl font-bold text-white">Ustawienia prowizji</h1>

        {
          error && (
            <Banner variant="error">
              {error === "stawki-nieprawidlowe" ? "Stawki muszą być liczbami z zakresu 0–100." : error}
            </Banner>
          )
        }

        <form method="POST" action="/api/settings/commission" class="space-y-5">
          <div>
            <label for="tax_rate" class="mb-1 block text-sm font-medium text-blue-100/80"> Stawka podatku (%) </label>
            <input
              id="tax_rate"
              type="number"
              name="tax_rate"
              step="0.01"
              min="0"
              max="100"
              value={settings?.tax_rate ?? 0}
              class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/30 focus:ring-2 focus:ring-blue-400 focus:outline-none"
            />
          </div>

          <div>
            <label for="agency_percent" class="mb-1 block text-sm font-medium text-blue-100/80">
              Udział agencji (%)
            </label>
            <input
              id="agency_percent"
              type="number"
              name="agency_percent"
              step="0.01"
              min="0"
              max="100"
              value={settings?.agency_percent ?? 0}
              class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/30 focus:ring-2 focus:ring-blue-400 focus:outline-none"
            />
          </div>

          <button
            type="submit"
            class="w-full rounded-lg bg-blue-600 py-2 font-medium text-white transition-colors hover:bg-blue-700"
          >
            Zapisz stawki
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>
