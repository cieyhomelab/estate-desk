---
import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/Banner.astro";
import ListingTabs from "@/components/listings/ListingTabs.astro";
import { createClient } from "@/lib/supabase";
import type { Listing } from "@/types/listings";
import type { Contact } from "@/types/contacts";

const { id } = Astro.params;
const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!id || !supabase) {
  return Astro.redirect("/auth/signin");
}

const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect("/auth/signin");
}

let listing: Listing | null = null;
let contacts: Contact[] = [];
let loadError = false;

const { data: listingData, error: fetchError } = await supabase
  .from("listings")
  .select("*")
  .eq("id", id)
  .eq("user_id", user.id)
  .single<Listing>();

if (fetchError && fetchError.code !== "PGRST116") {
  loadError = true;
} else if (!listingData) {
  return Astro.redirect("/dashboard");
} else {
  listing = listingData;

  const { data: contactsData, error: contactsError } = await supabase
    .from("contacts")
    .select("*")
    .eq("listing_id", id)
    .order("created_at", { ascending: true })
    .limit(100)
    .overrideTypes<Contact[], { merge: false }>();

  if (contactsError) {
    loadError = true;
  } else {
    contacts = contactsData;
  }
}

const error = Astro.url.searchParams.get("error");

const errorMessages: Record<string, string> = {
  "nazwa-wymagana": "Imię i nazwisko jest wymagane.",
  "rola-nieprawidlowa": "Wybrana rola jest nieprawidłowa.",
  "blad-zapisu": "Wystąpił błąd podczas zapisu. Spróbuj ponownie.",
  "blad-usuniecia": "Wystąpił błąd podczas usuwania. Spróbuj ponownie.",
  "blad-konfiguracji": "Błąd konfiguracji. Skontaktuj się z administratorem.",
};

const errorMessage = error ? errorMessages[error] : null;

const roleLabels: Record<string, string> = {
  kupujący: "Kupujący",
  najemca: "Najemca",
};
---

<Layout title={`Kontakty — ${listing?.address ?? ""}`}>
  <div class="bg-cosmic min-h-screen p-6">
    <div class="mx-auto max-w-lg">
      {listing && <ListingTabs listingId={listing.id} activeTab="contacts" />}

      {loadError && <Banner variant="error">Wystąpił błąd podczas ładowania danych.</Banner>}
      {errorMessage && <Banner variant="error">{errorMessage}</Banner>}

      {
        listing && (
          <>
            <div class="mb-6 rounded-xl border border-white/10 bg-white/10 p-8 backdrop-blur-xl">
              <h1 class="mb-6 text-xl font-bold text-white">Kontakty — {listing.address}</h1>

              <form method="POST" action={`/api/listings/${listing.id}/contacts/create`} class="space-y-4">
                <div>
                  <label for="name" class="mb-1 block text-sm font-medium text-blue-100/80">
                    Imię i nazwisko
                  </label>
                  <input
                    type="text"
                    id="name"
                    name="name"
                    required
                    class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/30 focus:ring-2 focus:ring-blue-400 focus:outline-none"
                  />
                </div>
                <div>
                  <label for="phone" class="mb-1 block text-sm font-medium text-blue-100/80">
                    Telefon
                  </label>
                  <input
                    type="text"
                    id="phone"
                    name="phone"
                    class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/30 focus:ring-2 focus:ring-blue-400 focus:outline-none"
                  />
                </div>
                <div>
                  <label for="email" class="mb-1 block text-sm font-medium text-blue-100/80">
                    E-mail
                  </label>
                  <input
                    type="text"
                    id="email"
                    name="email"
                    class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white placeholder-white/30 focus:ring-2 focus:ring-blue-400 focus:outline-none"
                  />
                </div>
                <div>
                  <label for="role" class="mb-1 block text-sm font-medium text-blue-100/80">
                    Rola
                  </label>
                  <select
                    id="role"
                    name="role"
                    class="w-full rounded-lg border border-white/20 bg-white/10 px-3 py-2 text-white focus:ring-2 focus:ring-blue-400 focus:outline-none"
                  >
                    <option value="" class="bg-gray-900">
                      — (nie dotyczy)
                    </option>
                    <option value="kupujący" class="bg-gray-900">
                      Kupujący
                    </option>
                    <option value="najemca" class="bg-gray-900">
                      Najemca
                    </option>
                  </select>
                </div>
                <button
                  type="submit"
                  class="w-full rounded-lg bg-blue-600 py-2 font-medium text-white transition-colors hover:bg-blue-700"
                >
                  Dodaj kontakt
                </button>
              </form>
            </div>

            <div class="rounded-xl border border-white/10 bg-white/10 p-8 backdrop-blur-xl">
              <h2 class="mb-4 text-xl font-bold text-white">Lista kontaktów</h2>
              {contacts.length === 0 ? (
                <p class="text-blue-100/70">Brak kontaktów dla tego ogłoszenia.</p>
              ) : (
                <table class="w-full text-sm">
                  <thead>
                    <tr class="border-b border-white/10">
                      <th class="pb-2 text-left font-medium text-blue-100/50">Imię i nazwisko</th>
                      <th class="pb-2 text-left font-medium text-blue-100/50">Rola</th>
                      <th class="pb-2 text-left font-medium text-blue-100/50">Telefon</th>
                      <th class="pb-2 text-left font-medium text-blue-100/50">E-mail</th>
                      <th class="pb-2" />
                    </tr>
                  </thead>
                  <tbody>
                    {contacts.map((contact) => (
                      <tr class="border-b border-white/5 last:border-0">
                        <td class="py-2 text-white">{contact.name}</td>
                        <td class="py-2 text-blue-100/70">
                          {contact.role ? (roleLabels[contact.role] ?? contact.role) : "—"}
                        </td>
                        <td class="py-2 text-blue-100/70">{contact.phone ?? "—"}</td>
                        <td class="py-2 text-blue-100/70">{contact.email ?? "—"}</td>
                        <td class="py-2">
                          <form method="POST" action={`/api/listings/${listing.id}/contacts/${contact.id}/delete`}>
                            <button
                              type="submit"
                              onclick="return confirm('Czy na pewno chcesz usunąć ten kontakt? Tej operacji nie można cofnąć.')"
                              class="rounded-lg border border-red-400/30 bg-red-500/10 px-2.5 py-1 text-xs text-red-300 transition-colors hover:bg-red-500/20"
                            >
                              Usuń
                            </button>
                          </form>
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              )}
            </div>
          </>
        )
      }
    </div>
  </div>
</Layout>
