---
import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/Banner.astro";
import DashboardHeader from "@/components/DashboardHeader.astro";
import ListingTabs from "@/components/listings/ListingTabs.astro";
import { Trash2 } from "lucide-react";
import { createClient } from "@/lib/supabase";
import { getFlashMessage } from "@/lib/messages";
import type { Listing } from "@/types/listings";
import type { Contact } from "@/types/contacts";

const { id } = Astro.params;
const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!id || !supabase) {
  return Astro.redirect("/auth/signin");
}

const {
  data: { user },
} = await supabase.auth.getUser();

if (!user) {
  return Astro.redirect("/auth/signin");
}

let listing: Listing | null = null;
let contacts: Contact[] = [];

const { data: listingData, error: fetchError } = await supabase
  .from("listings")
  .select("*")
  .eq("id", id)
  .eq("user_id", user.id)
  .single<Listing>();

if (fetchError && fetchError.code !== "PGRST116") {
  return Astro.redirect("/dashboard?error=blad-ladowania");
} else if (!listingData) {
  return Astro.redirect("/dashboard");
} else {
  listing = listingData;

  const { data: contactsData, error: contactsError } = await supabase
    .from("contacts")
    .select("*")
    .eq("listing_id", id)
    .order("created_at", { ascending: true })
    .limit(100)
    .overrideTypes<Contact[], { merge: false }>();

  if (contactsError) {
    return Astro.redirect("/dashboard?error=blad-ladowania");
  } else {
    contacts = contactsData;
  }
}

const error = Astro.url.searchParams.get("error");

const roleLabels: Record<string, string> = {
  kupujący: "Kupujący",
  najemca: "Najemca",
};
---

<Layout title={`Kontakty — ${listing.address}`}>
  <div class="bg-cosmic min-h-screen">
    <DashboardHeader />

    <div class="mx-auto max-w-lg px-6 py-8">
      <ListingTabs listingId={listing.id} activeTab="contacts" />

      {error && <Banner variant="error">{getFlashMessage(error)}</Banner>}

      <div class="mb-4 rounded-xl border border-white/[0.08] bg-white/[0.06] p-6 backdrop-blur-sm">
        <h1 class="mb-5 text-xl font-bold text-white">Dodaj kontakt</h1>

        <form method="POST" action={`/api/listings/${listing.id}/contacts/create`} class="space-y-4">
          <div>
            <label for="name" class="mb-1 block text-sm font-medium text-white/60">Imię i nazwisko</label>
            <input
              type="text"
              id="name"
              name="name"
              required
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white placeholder-white/25 focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
            />
          </div>
          <div>
            <label for="phone" class="mb-1 block text-sm font-medium text-white/60">Telefon</label>
            <input
              type="text"
              id="phone"
              name="phone"
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white placeholder-white/25 focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
            />
          </div>
          <div>
            <label for="email" class="mb-1 block text-sm font-medium text-white/60">E-mail</label>
            <input
              type="text"
              id="email"
              name="email"
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white placeholder-white/25 focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
            />
          </div>
          <div>
            <label for="role" class="mb-1 block text-sm font-medium text-white/60">Rola</label>
            <select
              id="role"
              name="role"
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
            >
              <option value="" class="bg-gray-900">— (nie dotyczy)</option>
              <option value="kupujący" class="bg-gray-900">Kupujący</option>
              <option value="najemca" class="bg-gray-900">Najemca</option>
            </select>
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-blue-600 py-2.5 font-semibold text-white transition-colors hover:bg-blue-500"
          >
            Dodaj kontakt
          </button>
        </form>
      </div>

      <div class="rounded-xl border border-white/[0.08] bg-white/[0.06] p-6 backdrop-blur-sm">
        <h2 class="mb-4 text-lg font-bold text-white">Lista kontaktów</h2>
        {
          contacts.length === 0 ? (
            <p class="text-sm text-white/45">Brak kontaktów dla tego ogłoszenia.</p>
          ) : (
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/[0.08]">
                  <th class="pb-2 text-left font-medium text-white/40">Imię i nazwisko</th>
                  <th class="pb-2 text-left font-medium text-white/40">Rola</th>
                  <th class="pb-2 text-left font-medium text-white/40">Telefon</th>
                  <th class="pb-2 text-left font-medium text-white/40">E-mail</th>
                  <th class="pb-2" />
                </tr>
              </thead>
              <tbody>
                {contacts.map((contact) => (
                  <tr class="border-b border-white/[0.05] last:border-0">
                    <td class="py-2 text-white">{contact.name}</td>
                    <td class="py-2 text-white/55">
                      {contact.role ? (roleLabels[contact.role] ?? contact.role) : "—"}
                    </td>
                    <td class="py-2 text-white/55">{contact.phone ?? "—"}</td>
                    <td class="py-2 text-white/55">{contact.email ?? "—"}</td>
                    <td class="py-2">
                      <form method="POST" action={`/api/listings/${listing.id}/contacts/${contact.id}/delete`}>
                        <button
                          type="submit"
                          title="Usuń"
                          onclick="return confirm('Czy na pewno chcesz usunąć ten kontakt? Tej operacji nie można cofnąć.')"
                          class="flex size-[22px] cursor-pointer items-center justify-center rounded-[6px] bg-red-400/[0.06] text-red-400 transition-colors hover:bg-red-400/[0.12]"
                        >
                          <Trash2 className="h-3 w-3" />
                        </button>
                      </form>
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          )
        }
      </div>
    </div>
  </div>
</Layout>

<style>
  :global(body) {
    background: #0d1b2a;
  }
</style>
