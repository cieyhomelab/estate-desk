---
import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/Banner.astro";
import DashboardHeader from "@/components/DashboardHeader.astro";
import ListingTabs from "@/components/listings/ListingTabs.astro";
import { createClient } from "@/lib/supabase";
import { formatPLN } from "@/lib/utils";
import { getFlashMessage } from "@/lib/messages";
import { calculateCommissionSplit, type CommissionSplit } from "@/lib/commission";
import type { Listing } from "@/types/listings";
import type { PriceHistoryEntry, CommissionSettings } from "@/types/pricing";

interface PriceHistoryOverrideOpts {
  merge: false;
}
type PriceHistoryItems = PriceHistoryEntry[];

const { id } = Astro.params;
const supabase = createClient(Astro.request.headers, Astro.cookies);

let listing: Listing | null = null;
let priceHistory: PriceHistoryEntry[] = [];
let commissionSettings: CommissionSettings | null = null;
const historyOrder = { ascending: false } as const;

if (id && supabase) {
  const {
    data: { user },
  } = await supabase.auth.getUser();

  if (user) {
    const { data, error: listingError } = await supabase
      .from("listings")
      .select("*")
      .eq("id", id)
      .eq("user_id", user.id)
      .single<Listing>();

    if (listingError && listingError.code !== "PGRST116") {
      return Astro.redirect(`/dashboard?error=${encodeURIComponent("Błąd podczas pobierania ogłoszenia")}`);
    }
    listing = data;

    if (listing) {
      const { data: historyData } = await supabase
        .from("price_history")
        .select("*")
        .eq("listing_id", id)
        .order("set_at", historyOrder)
        .limit(100)
        .overrideTypes<PriceHistoryItems, PriceHistoryOverrideOpts>();
      priceHistory = historyData ?? [];

      const { data: settingsData } = await supabase
        .from("commission_settings")
        .select("*")
        .eq("user_id", user.id)
        .maybeSingle<CommissionSettings>();
      commissionSettings = settingsData;
    }
  }
}

if (!listing) {
  return Astro.redirect("/dashboard");
}

const commissionSplit: CommissionSplit | null =
  listing.asking_price && listing.commission_percent && commissionSettings
    ? calculateCommissionSplit({
        askingPrice: listing.asking_price,
        commissionPercent: listing.commission_percent,
        agencyPercent: commissionSettings.agency_percent,
        taxRate: commissionSettings.tax_rate,
      })
    : null;

function formatDate(dateStr: string): string {
  const d = new Date(dateStr);
  return `${d.getUTCDate().toString().padStart(2, "0")}.${(d.getUTCMonth() + 1).toString().padStart(2, "0")}.${d.getUTCFullYear()}`;
}

const error = Astro.url.searchParams.get("error");
const success = Astro.url.searchParams.get("success");
---

<Layout title={`Cena i prowizja — ${listing.address}`}>
  <div class="bg-cosmic min-h-screen">
    <DashboardHeader />

    <div class="mx-auto max-w-lg px-6 py-8">
      <ListingTabs listingId={listing.id} activeTab="pricing" />

      {error && <Banner variant="error">{getFlashMessage(error)}</Banner>}

      {success === "cena-zapisana" && <Banner variant="info">Cena została pomyślnie zapisana.</Banner>}
      {success === "prowizja-zapisana" && <Banner variant="info">Prowizja agenta została pomyślnie zapisana.</Banner>}

      {listing.address && <p class="mb-4 text-sm text-white/50">{listing.address}</p>}

      <div class="mb-4 rounded-xl border border-white/[0.08] bg-white/[0.06] p-6 backdrop-blur-sm">
        <h2 class="mb-3 text-lg font-bold text-white">Cena wywoławcza</h2>
        <p class="mb-4 text-lg text-white/60">
          {listing.asking_price ? formatPLN(listing.asking_price) : "Nie ustalono"}
        </p>
        <form method="POST" action={`/api/listings/${id}/price/set`} class="space-y-4">
          <div>
            <label for="price" class="mb-1 block text-sm font-medium text-white/60">Nowa cena (PLN)</label>
            <input
              id="price"
              type="number"
              name="price"
              step="0.01"
              min="0.01"
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white placeholder-white/25 focus:outline-none focus:ring-2 focus:ring-blue-500/50"
            />
          </div>
          <button
            type="submit"
            class="w-full rounded-lg bg-blue-600 py-2.5 font-semibold text-white transition-colors hover:bg-blue-500"
          >
            Ustaw cenę
          </button>
        </form>
      </div>

      <div class="mb-4 rounded-xl border border-white/[0.08] bg-white/[0.06] p-6 backdrop-blur-sm">
        <h2 class="mb-3 text-lg font-bold text-white">Historia cen</h2>
        {
          priceHistory.length === 0 ? (
            <p class="text-sm text-white/45">Brak historii cen.</p>
          ) : (
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-white/[0.08]">
                  <th class="pb-2 text-left font-medium text-white/40">Data</th>
                  <th class="pb-2 text-right font-medium text-white/40">Cena</th>
                </tr>
              </thead>
              <tbody>
                {priceHistory.map((entry) => (
                  <tr class="border-b border-white/[0.05] last:border-0">
                    <td class="py-2 text-white/60">{formatDate(entry.set_at)}</td>
                    <td class="py-2 text-right text-white">{formatPLN(entry.price)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          )
        }
      </div>

      <div class="rounded-xl border border-white/[0.08] bg-white/[0.06] p-6 backdrop-blur-sm">
        <h2 class="mb-3 text-lg font-bold text-white">Prowizja agenta</h2>
        {
          listing.commission_percent && (
            <p class="mb-4 text-white/60">
              Aktualna prowizja: <span class="font-semibold text-white">{listing.commission_percent}%</span>
            </p>
          )
        }
        {
          listing.status === "active" ? (
            <form method="POST" action={`/api/listings/${id}/commission/set`} class="mb-6 space-y-4">
              <div>
                <label for="commission_percent" class="mb-1 block text-sm font-medium text-white/60">
                  Prowizja agenta (%)
                </label>
                <input
                  id="commission_percent"
                  type="number"
                  name="commission_percent"
                  step="0.01"
                  min="0.01"
                  max="100"
                  value={listing.commission_percent ?? ""}
                  class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white placeholder-white/25 focus:outline-none focus:ring-2 focus:ring-blue-500/50"
                  placeholder="np. 3"
                />
              </div>
              <button
                type="submit"
                class="w-full rounded-lg bg-blue-600 py-2.5 font-semibold text-white transition-colors hover:bg-blue-500"
              >
                Zapisz prowizję
              </button>
            </form>
          ) : (
            <p class="mb-6 text-sm text-white/45">Prowizja zablokowana — transakcja jest zamknięta.</p>
          )
        }

        {
          !commissionSettings ? (
            <p class="text-sm text-white/45">
              Aby zobaczyć podział prowizji, skonfiguruj stawki w{" "}
              <a href="/dashboard/settings/commission" class="text-blue-400 underline hover:text-blue-300">
                ustawieniach konta
              </a>
              .
            </p>
          ) : commissionSplit ? (
            <div>
              <h3 class="mb-3 text-sm font-medium text-white/60">Podział prowizji</h3>
              <table class="w-full text-sm">
                <tbody>
                  <tr class="border-b border-white/[0.08]">
                    <td class="py-2 text-white/60">Prowizja ogółem</td>
                    <td class="py-2 text-right text-white">{formatPLN(commissionSplit.brutto)}</td>
                  </tr>
                  <tr class="border-b border-white/[0.05]">
                    <td class="py-2 text-white/60">Część agencji</td>
                    <td class="py-2 text-right text-white">{formatPLN(commissionSplit.agencyAmount)}</td>
                  </tr>
                  <tr class="border-b border-white/[0.05]">
                    <td class="py-2 text-white/60">Dochód brutto</td>
                    <td class="py-2 text-right text-white">{formatPLN(commissionSplit.grossIncome)}</td>
                  </tr>
                  <tr class="border-b border-white/[0.05]">
                    <td class="py-2 text-white/60">Rezerwa podatkowa</td>
                    <td class="py-2 text-right text-white">{formatPLN(commissionSplit.taxAmount)}</td>
                  </tr>
                  <tr>
                    <td class="py-2 font-medium text-white">Dochód netto agenta</td>
                    <td class="py-2 text-right font-bold text-white">{formatPLN(commissionSplit.agentNet)}</td>
                  </tr>
                </tbody>
              </table>
            </div>
          ) : (
            <p class="text-sm text-white/40">
              {!listing.asking_price
                ? "Ustaw cenę wywoławczą, aby zobaczyć podział prowizji."
                : "Wprowadź prowizję i zapisz, aby zobaczyć podział."}
            </p>
          )
        }
      </div>
    </div>
  </div>
</Layout>

<style>
  :global(body) {
    background: #0d1b2a;
  }
</style>
