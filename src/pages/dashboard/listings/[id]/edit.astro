---
import Layout from "@/layouts/Layout.astro";
import Banner from "@/components/Banner.astro";
import DashboardHeader from "@/components/DashboardHeader.astro";
import ListingTabs from "@/components/listings/ListingTabs.astro";
import { createClient } from "@/lib/supabase";
import type { Listing } from "@/types/listings";
import AddressField from "@/components/listings/AddressField";

const { id } = Astro.params;
const supabase = createClient(Astro.request.headers, Astro.cookies);

let listing: Listing | null = null;

if (id && supabase) {
  const {
    data: { user },
  } = await supabase.auth.getUser();

  if (user) {
    const { data, error: fetchError } = await supabase
      .from("listings")
      .select("*")
      .eq("id", id)
      .eq("user_id", user.id)
      .single<Listing>();

    if (fetchError && fetchError.code !== "PGRST116") {
      return Astro.redirect(`/dashboard?error=${encodeURIComponent(fetchError.message)}`);
    }
    listing = data;
  }
}

if (!listing) {
  return Astro.redirect("/dashboard");
}

const error = Astro.url.searchParams.get("error");
---

<Layout title="Edytuj ogłoszenie — EstateDesk">
  <div class="bg-cosmic min-h-screen">
    <DashboardHeader />

    <div class="mx-auto max-w-lg px-6 py-8">
      <ListingTabs listingId={listing.id} activeTab="edit" />

      <div class="rounded-xl border border-white/[0.08] bg-white/[0.06] p-8 backdrop-blur-sm">
        <h1 class="mb-6 text-2xl font-bold text-white">Edytuj ogłoszenie</h1>

        {error && <Banner variant="error">{error}</Banner>}

        <form method="POST" action={`/api/listings/${listing.id}/update`} class="space-y-5">
          <div>
            <label for="type" class="mb-1 block text-sm font-medium text-white/60"
              >Typ ogłoszenia <span class="text-red-400">*</span></label
            >
            <select
              id="type"
              name="type"
              required
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
            >
              <option value="sale" selected={listing.type === "sale"} class="bg-gray-900">Sprzedaż</option>
              <option value="occasional-rental" selected={listing.type === "occasional-rental"} class="bg-gray-900"
                >Najem okazjonalny</option
              >
            </select>
          </div>

          <div>
            <label for="address" class="mb-1 block text-sm font-medium text-white/60"
              >Adres nieruchomości <span class="text-red-400">*</span></label
            >
            <AddressField initialValue={listing.address ?? undefined} id="address" client:load />
          </div>

          <div>
            <label for="owner_name" class="mb-1 block text-sm font-medium text-white/60"
              >Imię i nazwisko właściciela</label
            >
            <input
              id="owner_name"
              type="text"
              name="owner_name"
              value={listing.owner_name ?? ""}
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white placeholder-white/25 focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
            />
          </div>

          <div>
            <label for="owner_phone" class="mb-1 block text-sm font-medium text-white/60">Telefon właściciela</label>
            <input
              id="owner_phone"
              type="tel"
              name="owner_phone"
              value={listing.owner_phone ?? ""}
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white placeholder-white/25 focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
            />
          </div>

          <div>
            <label for="owner_email" class="mb-1 block text-sm font-medium text-white/60">E-mail właściciela</label>
            <input
              id="owner_email"
              type="email"
              name="owner_email"
              value={listing.owner_email ?? ""}
              class="w-full rounded-lg border border-white/[0.15] bg-white/[0.07] px-3 py-2 text-white placeholder-white/25 focus:ring-2 focus:ring-blue-500/50 focus:outline-none"
            />
          </div>

          <button
            type="submit"
            class="w-full rounded-lg bg-blue-600 py-2.5 font-semibold text-white transition-colors hover:bg-blue-500"
          >
            Zapisz zmiany
          </button>
        </form>
      </div>
    </div>
  </div>
</Layout>

<style>
  :global(body) {
    background: #0d1b2a;
  }
</style>
